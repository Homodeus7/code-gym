{
  "name": "code-gym",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "vanillajs": "pnpm --filter vanillajs dev",
    "vue": "pnpm --filter vue-tasks dev",
    "react": "pnpm --filter react-tasks dev",
    "format": "prettier --write \"vanillajs/**/*.{js,ts,json}\" \"vue/src/**/*.{vue,ts}\" \"react/src/**/*.{tsx,ts,css}\" \"*.{json,yaml,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.2"
  }
}
